# Vacation images are stored in a real remote S3-compatible bucket (e.g.
# Cloudflare R2) — no image files live in this repo, and there is no local
# MinIO container. Every machine that runs `docker compose up` needs the
# variables below in its own .env to see/manage images.
#
# Cloudflare R2 setup (see https://dash.cloudflare.com/ -> R2):
#   1. Create a bucket, e.g. "vacations-images"
#   2. R2 -> Manage R2 API Tokens -> Create API Token (Object Read & Write,
#      scoped to that bucket) -> copy the Access Key ID / Secret Access Key
#      (NOT the general account API token / "cfat_..." value)
#   3. Your endpoint is https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#      (ACCOUNT_ID is shown on the R2 overview page)
#   4. (Optional, recommended) Enable public read access on the bucket:
#      bucket -> Settings -> Public Access -> Allow Access via the r2.dev
#      subdomain -> copy the public URL (https://pub-xxxxxxxx.r2.dev)
MINIO_ENDPOINT=<ACCOUNT_ID>.r2.cloudflarestorage.com
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=your-r2-access-key-id
MINIO_SECRET_KEY=your-r2-secret-access-key
MINIO_BUCKET=vacations-images
MINIO_REGION=auto

# Optional — lets anyone VIEW images with zero credentials. The backend
# still needs MINIO_ACCESS_KEY/SECRET_KEY above to upload/delete images
# (writes always require authentication), but if set, the frontend loads
# images directly from this public URL, bypassing the backend for reads.
VITE_IMAGES_BASE_URL=https://pub-xxxxxxxx.r2.dev

# Enables the AI travel recommendation feature (leave unset to disable it)
VACATIONS_OPENAI_API_KEY=sk-your-openai-key-here

# Enables "Sign in with Google" (leave unset to disable it)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback
FRONTEND_URL=http://localhost

# Optional overrides — only needed if you want different values than the
# defaults already baked into docker-compose.yml
# VACATIONS_ENCRYPTION_KEY=your-jwt-secret-here
# MYSQL_ROOT_PASSWORD=RootSecure2024
# MYSQL_APP_USERNAME=vacations_app
# MYSQL_APP_PASSWORD=VacationsSecure2024