# Optional. `docker compose up --build` works with NO .env file at all — Mongo/MinIO
# credentials and the JWT signing key already have safe defaults baked into
# docker-compose.yml. Create a .env only to enable the features below or to
# override a default.

# Enables the AI travel recommendation feature (leave unset to disable it)
VACATIONS_OPENAI_API_KEY=sk-your-openai-key-here

# Enables "Sign in with Google" (leave unset to disable it)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback
FRONTEND_URL=http://localhost

# Optional overrides — only needed if you want different values than the
# defaults already baked into docker-compose.yml
# VACATIONS_ENCRYPTION_KEY=your-jwt-secret-here
# MINIO_ROOT_USER=minio_admin
# MINIO_ROOT_PASSWORD=MinioSecure2024
# MONGO_ROOT_USERNAME=mongo_admin
# MONGO_ROOT_PASSWORD=MongoSecure2024