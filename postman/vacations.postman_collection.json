{
  "info": {
    "name": "Vacations API",
    "_postman_id": "vacations-api-collection",
    "description": "Vacations Likes System - REST API\n\nAdmin credentials: admin@vacations.com / Admin1234\nTest user credentials: user@vacations.com / User1234\n\nAfter login/register the token is auto-saved to the {{token}} variable.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "vacationId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "    pm.collectionVariables.set('token', res.token);",
                  "    console.log('Token saved:', res.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"pass\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register a new user. Returns { user, token }.\n\nValidations:\n- All fields required\n- Valid email format\n- Password min 4 characters\n- Email must not already be registered (409 if duplicate)"
          }
        },
        {
          "name": "Register - Duplicate Email (should 409)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"pass\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Should return 409 - Email is already registered"
          }
        },
        {
          "name": "Register - Validation Error (should 422)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"\",\n  \"lastName\": \"Doe\",\n  \"email\": \"not-an-email\",\n  \"password\": \"ab\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Should return 422 - validation error"
          }
        },
        {
          "name": "Login - Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "    pm.collectionVariables.set('token', res.token);",
                  "    console.log('Token saved:', res.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@vacations.com\",\n  \"password\": \"Admin1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login as admin. Token auto-saved to {{token}}."
          }
        },
        {
          "name": "Login - Test User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "    pm.collectionVariables.set('token', res.token);",
                  "    console.log('Token saved:', res.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@vacations.com\",\n  \"password\": \"User1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login as regular user. Token auto-saved to {{token}}."
          }
        },
        {
          "name": "Login - Wrong Password (should 401)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@vacations.com\",\n  \"password\": \"wrongpassword\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Should return 401 - Incorrect email or password"
          }
        }
      ]
    },
    {
      "name": "Vacations",
      "item": [
        {
          "name": "Get All (page 1)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.vacations && res.vacations.length > 0) {",
                  "    pm.collectionVariables.set('vacationId', res.vacations[0]._id);",
                  "    console.log('vacationId saved:', res.vacations[0]._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/vacations?page=1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vacations"],
              "query": [{ "key": "page", "value": "1" }]
            },
            "description": "Returns 9 vacations per page with likesCount and isLiked per user.\nAlso saves first vacationId to {{vacationId}}."
          }
        },
        {
          "name": "Get All - Filter: liked",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/vacations?filter=liked",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vacations"],
              "query": [{ "key": "filter", "value": "liked" }]
            }
          }
        },
        {
          "name": "Get All - Filter: active",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/vacations?filter=active",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vacations"],
              "query": [{ "key": "filter", "value": "active" }]
            }
          }
        },
        {
          "name": "Get All - Filter: upcoming",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/vacations?filter=upcoming",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vacations"],
              "query": [{ "key": "filter", "value": "upcoming" }]
            }
          }
        },
        {
          "name": "Get One",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/vacations/{{vacationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vacations", "{{vacationId}}"]
            },
            "description": "Requires {{vacationId}} — run 'Get All' first to auto-populate it."
          }
        },
        {
          "name": "Add Vacation (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res._id) {",
                  "    pm.collectionVariables.set('vacationId', res._id);",
                  "    console.log('New vacationId saved:', res._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "destination", "value": "Test Destination",   "type": "text" },
                { "key": "description", "value": "A lovely test vacation.", "type": "text" },
                { "key": "startDate",   "value": "2027-01-01",          "type": "text" },
                { "key": "endDate",     "value": "2027-01-15",          "type": "text" },
                { "key": "price",       "value": "999",                 "type": "text" },
                { "key": "image",       "type": "file", "src": [] }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/vacations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vacations"]
            },
            "description": "Admin only (login as admin first).\nSend as form-data. Attach any image file to the 'image' field.\nSaved vacationId auto-set to {{vacationId}}."
          }
        },
        {
          "name": "Update Vacation (admin)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "destination", "value": "Updated Destination", "type": "text" },
                { "key": "description", "value": "Updated description.",  "type": "text" },
                { "key": "startDate",   "value": "2027-02-01",           "type": "text" },
                { "key": "endDate",     "value": "2027-02-15",           "type": "text" },
                { "key": "price",       "value": "1200",                 "type": "text" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/vacations/{{vacationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vacations", "{{vacationId}}"]
            },
            "description": "Admin only. Image field is optional — omit to keep existing image."
          }
        },
        {
          "name": "Delete Vacation (admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/vacations/{{vacationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vacations", "{{vacationId}}"]
            },
            "description": "Admin only. Also deletes the vacation image and all its likes. Returns 204."
          }
        },
        {
          "name": "Get All - No token (should 401)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/vacations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vacations"]
            }
          }
        }
      ]
    },
    {
      "name": "Likes",
      "item": [
        {
          "name": "Like a Vacation",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/likes/{{vacationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "likes", "{{vacationId}}"]
            },
            "description": "Like a vacation. Returns { likesCount }. Run 'Get All' first to populate {{vacationId}}."
          }
        },
        {
          "name": "Like Again (should 409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/likes/{{vacationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "likes", "{{vacationId}}"]
            },
            "description": "Should return 409 - You have already liked this vacation"
          }
        },
        {
          "name": "Unlike a Vacation",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/likes/{{vacationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "likes", "{{vacationId}}"]
            },
            "description": "Unlike a vacation. Returns { likesCount }."
          }
        },
        {
          "name": "Unlike Again (should 404)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/likes/{{vacationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "likes", "{{vacationId}}"]
            },
            "description": "Should return 404 - You have not liked this vacation"
          }
        },
        {
          "name": "Get All - Filter liked (verify)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/vacations?filter=liked",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vacations"],
              "query": [{ "key": "filter", "value": "liked" }]
            },
            "description": "After liking, this should return that vacation with isLiked: true"
          }
        }
      ]
    },
    {
      "name": "Report (admin only)",
      "item": [
        {
          "name": "Get Report",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/report",
              "host": ["{{baseUrl}}"],
              "path": ["api", "report"]
            },
            "description": "Admin only. Returns all vacations with their like counts, sorted by destination."
          }
        },
        {
          "name": "Download CSV",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/report/csv",
              "host": ["{{baseUrl}}"],
              "path": ["api", "report", "csv"]
            },
            "description": "Admin only. Downloads 'Vacation Likes.csv' with Destination,Likes columns."
          }
        },
        {
          "name": "Get Report as User (should 403)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/report",
              "host": ["{{baseUrl}}"],
              "path": ["api", "report"]
            },
            "description": "Login as regular user first, then send — should return 403 Access denied"
          }
        }
      ]
    }
  ]
}
